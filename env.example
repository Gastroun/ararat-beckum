# ══════════════════════════════════════════════════════════════
# ARARAT GRILL – Umgebungsvariablen
# Kopiere diese Datei als ".env" und trage alle Werte ein.
# NIEMALS die .env Datei auf GitHub hochladen!
# ══════════════════════════════════════════════════════════════

# ── MONGODB ──────────────────────────────────────────────────
# Von MongoDB Atlas → Connect → Drivers → Connection String
# Datenbankname am Ende anpassen (z.B. /ararat-grill)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORT@cluster0.xxxxx.mongodb.net/ararat-grill

# ── STRIPE ───────────────────────────────────────────────────
# Von stripe.com → Dashboard → Entwickler → API-Schlüssel
STRIPE_SECRET_KEY=sk_live_DEIN_STRIPE_SECRET_KEY

# Von stripe.com → Dashboard → Webhooks → Endpunkt erstellen
# URL: https://DEIN-BACKEND.onrender.com/api/stripe-webhook
# Event: checkout.session.completed + checkout.session.expired
STRIPE_WEBHOOK_SECRET=whsec_DEIN_WEBHOOK_SECRET

# ── RESEND (E-Mail) ───────────────────────────────────────────
# Von resend.com → API Keys → API Key erstellen
RESEND_API_KEY=re_DEIN_RESEND_API_KEY

# Absender (muss verifizierte Domain bei Resend sein)
EMAIL_FROM=bestellungen@ararat-grill.de

# E-Mail des Wirts (bekommt Kopie jeder Bestellung)
RESTAURANT_EMAIL=info@ararat-grill.de

# ── PRINTNODE (Bondrucker) ────────────────────────────────────
# Von printnode.com → API Keys
# Leer lassen wenn kein Drucker vorhanden
PRINTNODE_API_KEY=DEIN_PRINTNODE_API_KEY

# Drucker-ID aus PrintNode Dashboard
PRINTNODE_PRINTER_ID=12345

# ── ADMIN DASHBOARD ───────────────────────────────────────────
# Passwort für den Wirt (frei wählbar, mind. 12 Zeichen)
ADMIN_PASSWORD=Ararat2025Admin!

# Geheimer Token (mind. 40 Zeichen, zufällig – MUSS gleich
# sein wie ADMIN_API_TOKEN in admin.html!)
ADMIN_TOKEN_SECRET=AraratGeheimToken2025xyzABCDEFGHIJKLMNOP

# ── SERVER ────────────────────────────────────────────────────
# Port (Render setzt automatisch, nicht ändern)
PORT=3001

# WhatsApp Nummer des Restaurants (mit Ländervorwahl, ohne + oder Leerzeichen)
# Beispiel: 4915123456789 (49 = Deutschland, dann Nummer ohne führende 0)
WHATSAPP_NUMBER=4915123456789

# URL der Speisekarte (für Stripe success_url / CORS)
# Nach dem Render-Deploy eintragen
FRONTEND_URL=https://ararat-grill-beckum.onrender.com
